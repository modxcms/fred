  "properties": {
    "remote": {
      "description": "Determine whether to render the element remotely.",
      "type": "boolean"
    },
    "cacheOutput": {
      "description": "Whether or not to cache the output of an element to static HTML when remote is set to true.",
      "type": "boolean"
    },
    "mediaSource": {
      "description": "Comma-separated names of the media sources to use for the Finder.",
      "type": "string"
    },
    "imageMediaSource": {
      "description": "Comma-separated names of the media sources to use for the Finder specific for image selection.",
      "type": "string"
    },
    "toolbarPluginsInclude": {
      "description": "List of toolbar plugins to enable for elements.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "toolbarPluginsExclude": {
      "description": "List of toolbar plugins to disable for elements.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "settings": {
      "description": "Settings are made of a JSON array of option objects, which provide configuration controls for the element.",
