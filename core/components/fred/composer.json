{
  "require": {
    "twig/twig": "^3.27",
    "wa72/htmlpagedom": "^3.1",
    "ramsey/uuid": "^4.9.3",
    "symfony/dom-crawler": "^6.4",
    "symfony/css-selector": "^6.4",
    "symfony/filesystem": "^6.4",
    "symfony/finder": "^6.4",
    "firebase/php-jwt": "^7.1",
    "intervention/image": "^2.7",
    "studio-42/elfinder": "^2.1",
    "psr/http-message": "^1.1",
    "league/glide": "^2.3"
  },
  "replace": {
    "guzzlehttp/psr7": "*"
  },
  "config": {
    "platform": {
      "php": "8.1"
    }
  },
  "autoload": {
    "psr-4": {
      "Fred\\": "src/"
    }
  },
  "require-dev": {
