  },
  "scripts": {
    "post-install-cmd": "cp -r vendor/studio-42/elfinder/css  vendor/studio-42/elfinder/js vendor/studio-42/elfinder/img vendor/studio-42/elfinder/sounds ../../../assets/components/fred/web/vendor/elfinder/",
    "post-update-cmd": "cp -r vendor/studio-42/elfinder/css  vendor/studio-42/elfinder/js vendor/studio-42/elfinder/img vendor/studio-42/elfinder/sounds ../../../assets/components/fred/web/vendor/elfinder/"
